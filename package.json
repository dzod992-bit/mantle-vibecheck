{
  "name": "mantle-vibecheck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && hardhat test",
    "test:unit": "vitest run",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy:local": "hardhat run scripts/deploy-audit-registry.ts",
    "contracts:deploy:mantle": "hardhat run scripts/deploy-audit-registry.ts --network mantleSepolia",
    "contracts:rotate-signer:mantle": "hardhat run scripts/rotate-trusted-signer.ts --network mantleSepolia",
    "contracts:verification-input": "node scripts/export-verification-input.mjs"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "solc": "0.8.23-fixed",
    "viem": "2.52.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "^3.0.10",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.17",
    "@nomicfoundation/hardhat-viem": "^3.0.9",
    "@nomicfoundation/hardhat-viem-assertions": "^3.1.1",
    "@openzeppelin/contracts": "5.4.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "hardhat": "^3.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@actions/http-client": "4.0.1",
    "postcss": "8.5.15",
    "tmp": "0.2.6"
  }
